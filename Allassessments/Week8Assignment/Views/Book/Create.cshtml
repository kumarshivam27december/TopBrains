@model Book
@{
    ViewData["Title"] = "Add Book";
}

<h1>Add Book</h1>
<form asp-action="Create" method="post">
    <div asp-validation-summary="All" class="validation-summary"></div>
    <div class="form-row">
        <label asp-for="Title">Title</label>
        <input asp-for="Title" />
    </div>
    <div class="form-row">
        <label asp-for="Author">Author</label>
        <input asp-for="Author" />
    </div>
    <div class="form-row">
        <label asp-for="Price">Price</label>
        <input asp-for="Price" type="number" step="0.01" />
    </div>
    <button type="submit" class="button-primary">Add</button>
    <a asp-action="List" class="button-secondary">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
