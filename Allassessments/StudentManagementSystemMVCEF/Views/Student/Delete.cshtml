@model StudentManagementSystemMVCEF.Models.Student

@{
    ViewData["Title"] = "Delete Student";
}

<h2>Delete Student</h2>

<div class="alert alert-warning">
    Are you sure you want to delete this student?
</div>

<dl class="row">
    <dt class="col-sm-2">Name</dt>
    <dd class="col-sm-10">@Model.Name</dd>

    <dt class="col-sm-2">Email</dt>
    <dd class="col-sm-10">@Model.Email</dd>

    <dt class="col-sm-2">Department</dt>
    <dd class="col-sm-10">@(Model.Department?.DepartmentName ?? Model.DepartmentId.ToString())</dd>
</dl>

<form asp-action="DeleteConfirmed" method="post">
    <input type="hidden" name="id" value="@Model.StudentId" />
    <button type="submit" class="btn btn-primary">Delete</button>
    <a asp-action="Index" class="btn btn-primary">Cancel</a>
</form>

