@model IEnumerable<StudentManagementSystemMVCEF.Models.Student>

@{
    ViewData["Title"] = "Student List";
}

<h2>Student List</h2>

<a asp-action="Create" class="btn btn-primary">Add Student</a>

<form asp-action="Search" method="get" class="mt-3 mb-3">
    <div class="row">
        <div class="col-md-4">
            <input name="name" value="@ViewBag.SearchName" class="form-control" placeholder="Search by name" />
        </div>
        <div class="col-md-4">
            <select name="departmentId" class="form-control" asp-items="@(ViewBag.Departments as SelectList)">
                <option value="">All Departments</option>
            </select>
        </div>
        <div class="col-md-4">
            <button type="submit" class="btn btn-secondary">Search</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
        </div>
    </div>
</form>

<table class="table table-bordered mt-3">
    <thead>
        <tr>
            <th>StudentID</th>
            <th>Name</th>
            <th>Age</th>
            <th>Email</th>
            <th>Department</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.StudentId</td>
                <td>@item.Name</td>
                <td>@item.Age</td>
                <td>@item.Email</td>
                <td>@(item.Department?.DepartmentName ?? item.DepartmentId.ToString())</td>

                <td>
                    <a asp-action="Details" asp-route-id="@item.StudentId" class="btn btn-info">Details</a>
                    <a asp-action="Edit" asp-route-id="@item.StudentId" class="btn btn-info">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.StudentId" class="btn btn-info">Delete</a>
                </td>
            </tr>
        }
    </tbody>

</table>