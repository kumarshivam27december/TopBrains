@model IEnumerable<DepartmentStudentCountVm>
@{
    ViewData["Title"] = "Department Report";
}

<div class="d-flex justify-content-between align-items-end mb-3">
    <div>
        <h1 class="h3 mb-1">Department Wise Student Report</h1>
        <div class="text-muted">Total students per department</div>
    </div>
    <a class="btn btn-outline-secondary" asp-controller="Student" asp-action="Index">Back</a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-bordered align-middle">
        <thead class="table-light">
            <tr>
                <th>Department</th>
                <th style="width: 180px;">Total Students</th>
                <th style="width: 120px;"></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var row in Model)
        {
            <tr>
                <td>
                    <span class="badge bg-primary">@row.DepartmentName</span>
                </td>
                <td>@row.TotalStudents</td>
                <td class="text-nowrap">
                    <a class="btn btn-sm btn-outline-primary" asp-controller="Student" asp-action="ByDepartment" asp-route-id="@row.DepartmentId">
                        View Students
                    </a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

