@model IEnumerable<Department>
@{
    ViewData["Title"] = "Departments";
}

<div class="d-flex justify-content-between align-items-end mb-3">
    <div>
        <h1 class="h3 mb-1">Departments</h1>
        <div class="text-muted">Create and manage departments</div>
    </div>
    <a class="btn btn-primary" asp-action="Create">Add Department</a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-bordered align-middle">
        <thead class="table-light">
            <tr>
                <th>Department Name</th>
                <th>Location</th>
                <th style="width: 140px;">Courses</th>
                <th style="width: 180px;"></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.DepartmentName</td>
                <td>@item.Location</td>
                <td>@(item.Courses?.Count ?? 0)</td>
                <td class="text-nowrap">
                    <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.DepartmentId">Edit</a>
                    <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.DepartmentId">Details</a>
                    <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.DepartmentId">Delete</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

