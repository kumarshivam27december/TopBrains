@model Department
@{
    ViewData["Title"] = "Department Details";
}

<div class="d-flex justify-content-between align-items-end mb-3">
    <div>
        <h1 class="h3 mb-1">Department Details</h1>
        <div class="text-muted">@Model.DepartmentName</div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.DepartmentId">Edit</a>
        <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Location</dt>
                    <dd class="col-sm-8">@Model.Location</dd>
                    <dt class="col-sm-4">Courses</dt>
                    <dd class="col-sm-8">@Model.Courses.Count</dd>
                    <dt class="col-sm-4">Students</dt>
                    <dd class="col-sm-8">@Model.Students.Count</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-header fw-semibold">Courses</div>
            <div class="card-body p-0">
                <table class="table table-striped table-bordered mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Course</th>
                            <th style="width: 140px;">Duration</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var c in Model.Courses.OrderBy(c => c.CourseName))
                    {
                        <tr>
                            <td>@c.CourseName</td>
                            <td>@c.Duration</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

