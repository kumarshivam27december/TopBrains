@model Course
@{
    ViewData["Title"] = "Course Details";
}

<div class="d-flex justify-content-between align-items-end mb-3">
    <div>
        <h1 class="h3 mb-1">Course Details</h1>
        <div class="text-muted">@Model.CourseName</div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.CourseId">Edit</a>
        <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Duration</dt>
            <dd class="col-sm-9">@Model.Duration</dd>
            <dt class="col-sm-3">Department</dt>
            <dd class="col-sm-9">
                <span class="badge bg-primary">@Model.Department?.DepartmentName</span>
            </dd>
            <dt class="col-sm-3">Enrolled Students</dt>
            <dd class="col-sm-9">@Model.Students.Count</dd>
        </dl>
    </div>
</div>

