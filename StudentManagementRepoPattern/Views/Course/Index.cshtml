@model IEnumerable<Course>
@{
    ViewData["Title"] = "Courses";
}

<div class="d-flex justify-content-between align-items-end mb-3">
    <div>
        <h1 class="h3 mb-1">Courses</h1>
        <div class="text-muted">Create and manage courses</div>
    </div>
    <a class="btn btn-primary" asp-action="Create">Add Course</a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-bordered align-middle">
        <thead class="table-light">
            <tr>
                <th>Course Name</th>
                <th style="width: 140px;">Duration</th>
                <th>Department</th>
                <th style="width: 180px;"></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.CourseName</td>
                <td>@item.Duration</td>
                <td>
                    <span class="badge bg-primary-subtle text-primary border border-primary-subtle">
                        @item.Department?.DepartmentName
                    </span>
                </td>
                <td class="text-nowrap">
                    <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.CourseId">Edit</a>
                    <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.CourseId">Details</a>
                    <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.CourseId">Delete</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

