@model Student
@{
    ViewData["Title"] = "Student Details";
}

<div class="d-flex justify-content-between align-items-end mb-3">
    <div>
        <h1 class="h3 mb-1">Student Details</h1>
        <div class="text-muted">@Model.Name</div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.StudentId">Edit</a>
        <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3">Age</dt>
            <dd class="col-sm-9">@Model.Age</dd>

            <dt class="col-sm-3">Gender</dt>
            <dd class="col-sm-9">@Model.Gender</dd>

            <dt class="col-sm-3">Admission Date</dt>
            <dd class="col-sm-9">@Model.AdmissionDate.ToString("yyyy-MM-dd")</dd>

            <dt class="col-sm-3">Department</dt>
            <dd class="col-sm-9">
                <span class="badge bg-primary">@Model.Department?.DepartmentName</span>
            </dd>

            <dt class="col-sm-3">Course</dt>
            <dd class="col-sm-9">
                <span class="badge bg-success">@Model.Course?.CourseName</span>
            </dd>
        </dl>
    </div>
</div>

