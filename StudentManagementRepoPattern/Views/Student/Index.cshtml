@model IEnumerable<Student>
@{
    ViewData["Title"] = "Students";
    var filterTitle = ViewBag.FilterTitle as string;
    var searchName = ViewBag.SearchName as string;
}

<div class="d-flex flex-wrap gap-2 justify-content-between align-items-end mb-3">
    <div>
        <h1 class="h3 mb-1">Students</h1>
        @if (!string.IsNullOrWhiteSpace(filterTitle))
        {
            <div class="text-muted">@filterTitle</div>
        }
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-primary" asp-action="Create">Add Student</a>
        <a class="btn btn-outline-secondary" asp-action="ExportJson">Export JSON</a>
        <a class="btn btn-outline-dark" asp-action="TotalStudentsPerDepartment">Department Report</a>
    </div>
</div>

<form class="row g-2 mb-3" asp-action="Search" method="get">
    <div class="col-md-6">
        <input class="form-control" name="name" value="@searchName" placeholder="Search student by name..." />
    </div>
    <div class="col-md-2">
        <button class="btn btn-outline-primary w-100" type="submit">Search</button>
    </div>
    <div class="col-md-4 d-flex gap-2 justify-content-md-end">
        <a class="btn btn-outline-secondary" asp-action="OlderThan25">Age &gt; 25</a>
        <a class="btn btn-outline-secondary" asp-action="AdmittedAfter2024">Admitted After 2024</a>
        <a class="btn btn-outline-secondary" asp-action="Top5RecentAdmissions">Top 5</a>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-striped table-bordered align-middle">
        <thead class="table-light">
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Age</th>
                <th>Gender</th>
                <th>Admission Date</th>
                <th>Department</th>
                <th>Course</th>
                <th style="width: 180px;"></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Email</td>
                <td>@item.Age</td>
                <td>@item.Gender</td>
                <td>@item.AdmissionDate.ToString("yyyy-MM-dd")</td>
                <td>
                    <span class="badge bg-primary-subtle text-primary border border-primary-subtle">
                        @item.Department?.DepartmentName
                    </span>
                </td>
                <td>
                    <span class="badge bg-success-subtle text-success border border-success-subtle">
                        @item.Course?.CourseName
                    </span>
                </td>
                <td class="text-nowrap">
                    <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.StudentId">Edit</a>
                    <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.StudentId">Details</a>
                    <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.StudentId">Delete</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

