@model Student
@{
    ViewData["Title"] = "Delete Student";
}

<div class="d-flex justify-content-between align-items-end mb-3">
    <div>
        <h1 class="h3 mb-1">Delete Student</h1>
        <div class="text-muted">This action cannot be undone</div>
    </div>
    <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
</div>

<div class="alert alert-warning">
    Are you sure you want to delete <strong>@Model.Name</strong>?
</div>

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>
            <dt class="col-sm-3">Department</dt>
            <dd class="col-sm-9">@Model.Department?.DepartmentName</dd>
            <dt class="col-sm-3">Course</dt>
            <dd class="col-sm-9">@Model.Course?.CourseName</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="StudentId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
</form>

